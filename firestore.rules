rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /reports/{reportId} {
      // Qualquer usuário autenticado (com login Google) tem acesso total:
      // todos veem, criam, editam e excluem todos os relatórios.
      allow read, delete: if request.auth != null;

      allow create: if request.auth != null
        && isValidReport(request.resource.data);

      allow update: if request.auth != null
        && isValidReport(request.resource.data);
    }

    match /users/{uid} {
      // Qualquer usuário logado pode ler a lista (necessário para a tela de
      // gestão de usuários dos admins, e para o próprio usuário ver seu status).
      allow read: if request.auth != null;

      // Um usuário só pode criar o PRÓPRIO perfil, e só pode se dar como
      // "pending" (nunca se auto-aprovar ou virar admin nessa criação).
      // Administradores (por e-mail) podem criar já como admin aprovado.
      allow create: if request.auth != null
        && request.auth.uid == uid
        && request.resource.data.uid == uid
        && request.resource.data.email == request.auth.token.email
        && (
             (isAdminEmail(request.auth.token.email)
                && request.resource.data.role == 'admin'
                && request.resource.data.status == 'approved')
             || (!isAdminEmail(request.auth.token.email)
                && request.resource.data.role == 'user')
           );

      // Admins (pelo campo role do PRÓPRIO perfil, não só a lista fixa)
      // podem alterar status/role de qualquer usuário (aprovar, recusar,
      // revogar, promover/rebaixar). O próprio usuário pode atualizar dados
      // de exibição (nome/foto), mas nunca o próprio status ou role.
      allow update: if request.auth != null
        && (
             isAdminByRole()
             || (request.auth.uid == uid
                  && request.resource.data.status == resource.data.status
                  && request.resource.data.role == resource.data.role)
           );

      // Só administradores (pelo campo role do próprio perfil) podem excluir
      // perfis de usuário.
      allow delete: if request.auth != null && isAdminByRole();
    }

    function isAdminEmail(email) {
      return email in ['sidneibogas@gmail.com', 'claudiosantinao078@gmail.com', 'imc.sidnei@gmail.com'];
    }

    // Confere se quem está fazendo a requisição é admin de acordo com o
    // próprio documento salvo em /users (permite que administradores
    // promovidos depois, e não só os 3 e-mails fixos, também gerenciem
    // outros usuários).
    function isAdminByRole() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Validações de schema compartilhadas entre create e update
    function isValidReport(data) {
      return data.numeroRelatorio is string && data.numeroRelatorio.size() > 0 && data.numeroRelatorio.size() <= 50
        && data.evento is string && data.evento.size() > 0 && data.evento.size() <= 300
        && data.regional is string && data.regional.size() > 0 && data.regional.size() <= 300
        && data.comando is string && data.comando.size() > 0 && data.comando.size() <= 300
        && data.responsavel is string && data.responsavel.size() > 0 && data.responsavel.size() <= 200
        && data.conferidoPor is string && data.conferidoPor.size() > 0 && data.conferidoPor.size() <= 200
        && data.descricao is string && data.descricao.size() > 0 && data.descricao.size() <= 10000
        && (!('participantes' in data) || (data.participantes is string && data.participantes.size() <= 5000))
        && data.data is string && data.data.matches('^[0-9]{4}-[0-9]{2}-[0-9]{2}$')
        && data.hora is string && data.hora.matches('^[0-9]{2}:[0-9]{2}$')
        // fotoUrl agora é uma data URL base64 (a foto comprimida é salva direto no
        // documento — sem Firebase Storage). O limite abaixo dá folga para até ~900KB
        // de imagem em base64, ficando ainda assim dentro do limite de 1MiB do documento.
        && (!('fotoUrl' in data) || (data.fotoUrl is string && data.fotoUrl.size() <= 900000));
    }
  }
}
