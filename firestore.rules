rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /reports/{reportId} {
      // Qualquer usuário autenticado (com login Google) tem acesso total:
      // todos veem, criam, editam e excluem todos os relatórios.
      allow read, delete: if request.auth != null;

      allow create: if request.auth != null
        && isValidReport(request.resource.data);

      allow update: if request.auth != null
        && isValidReport(request.resource.data);
    }

    // Validações de schema compartilhadas entre create e update
    function isValidReport(data) {
      return data.numeroRelatorio is string && data.numeroRelatorio.size() > 0 && data.numeroRelatorio.size() <= 50
        && data.evento is string && data.evento.size() > 0 && data.evento.size() <= 300
        && data.local is string && data.local.size() > 0 && data.local.size() <= 300
        && data.responsavel is string && data.responsavel.size() > 0 && data.responsavel.size() <= 200
        && data.conferidoPor is string && data.conferidoPor.size() > 0 && data.conferidoPor.size() <= 200
        && data.descricao is string && data.descricao.size() > 0 && data.descricao.size() <= 10000
        && (!('participantes' in data) || (data.participantes is string && data.participantes.size() <= 5000))
        && data.data is string && data.data.matches('^[0-9]{4}-[0-9]{2}-[0-9]{2}$')
        && data.hora is string && data.hora.matches('^[0-9]{2}:[0-9]{2}$')
        // fotoUrl agora é uma data URL base64 (a foto comprimida é salva direto no
        // documento — sem Firebase Storage). O limite abaixo dá folga para até ~900KB
        // de imagem em base64, ficando ainda assim dentro do limite de 1MiB do documento.
        && (!('fotoUrl' in data) || (data.fotoUrl is string && data.fotoUrl.size() <= 900000));
    }
  }
}
